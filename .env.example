# =============================================================================
# Autonomous Trading System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers - Choose ONE (required for analysis)
# -----------------------------------------------------------------------------
# Default: OpenRouter with free Step-3.5 model
OPENROUTER_API_KEY=

# Alternative providers (uncomment and fill if using instead)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=

# -----------------------------------------------------------------------------
# Alpaca Paper Trading - Required for live trade execution
# -----------------------------------------------------------------------------
# Get your free API keys at: https://app.alpaca.markets/
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=

# -----------------------------------------------------------------------------
# Autonomous Trader Settings (optional overrides)
# -----------------------------------------------------------------------------
# HERMES_AUTO_DRY_RUN=true
# HERMES_AUTO_RESEARCH_TIME="18:00"
# HERMES_AUTO_MIN_CONFIDENCE=0.65
