# =============================================================================
# Autonomous Crypto Trading System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers - Choose ONE (required for analysis)
# -----------------------------------------------------------------------------
# Default: OpenRouter with free Step-3.5 model
OPENROUTER_API_KEY=

# Alternative providers (uncomment and fill if using instead)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# DEEPSEEK_API_KEY=
# TOGETHER_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# -----------------------------------------------------------------------------
# Bybit Trading - Required for trade execution
# -----------------------------------------------------------------------------
# Get your testnet API keys at: https://testnet.bybit.com/
# Get live API keys at: https://www.bybit.com/
BYBIT_API_KEY=
BYBIT_API_SECRET=

# -----------------------------------------------------------------------------
# Crypto Data Providers
# -----------------------------------------------------------------------------
# CoinGecko - Free tier available, higher limits with API key
# Get key at: https://www.coingecko.com/
COINGECKO_API_KEY=

# CoinMarketCap - Pro API required for trending endpoint
# Get key at: https://coinmarketcap.com/
COINMARKETCAP_API_KEY=

# CryptoPanic - News aggregation
# Get key at: https://cryptopanic.com/
CRYPTOPANIC_API_KEY=

# Reddit API - For social sentiment analysis
# Get keys at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# On-Chain Data (optional - free tier)
# -----------------------------------------------------------------------------
# Glassnode - Get key at: https://www.glassnode.com/
GLASSNODE_API_KEY=

# DeFiLlama - TVL data (free, no key required for basic use)
# DEFLLAMA_API_KEY=

# -----------------------------------------------------------------------------
# Autonomous Trader Settings (optional overrides)
# -----------------------------------------------------------------------------
# DRY_RUN=true                # Paper trading mode
# RESEARCH_TIME="18:00"       # When to run research
# MIN_CONFIDENCE=0.65         # Minimum signal confidence